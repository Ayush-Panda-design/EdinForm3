# =============================================================================
# FormCraft — Environment Variables
# =============================================================================

# Database
DATABASE_URL=postgresql://postgres:password@localhost:55422/formcraft

# API Server
PORT=8000
NODE_ENV=development
BASE_URL=http://localhost:8000
APP_URL=http://localhost:3000

# Security — REQUIRED in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-at-least-32-chars

# Optional: Upstash Redis — distributed rate limiting (falls back to in-memory)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# Optional: Resend — email notifications (falls back to console.log)
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=FormCraft <noreply@formcraft.io>

# Optional: Snyk — dependency security scanning
# SNYK_TOKEN=xxx

# Google OAuth (optional — enables "Sign in with Google")
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# 3. Set Authorized redirect URI to: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend: API base URL (without /trpc) — used to build the Google auth redirect URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
